    "pw:api": "npm run bddgen && playwright test --grep \"@api\"",
    "test": "npm run pw:test",
    "pw:smoke": "npm run bddgen && playwright test --grep \"@smoke\"",
    "pw:ui": "npm run bddgen && playwright test --grep \"@ui\"",
